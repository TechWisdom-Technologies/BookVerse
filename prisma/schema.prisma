generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  VISITOR
  MEMBER
  AUTHOR
  ADMIN
}

enum FileType {
  PDF
  EPUB
}

enum ReactionType {
  LIKE
  LOVE
  FIRE
  CRY
  WOW
}

enum ClubRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ChapterStatus {
  DRAFT
  BETA
  PUBLISHED
}

enum TipStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique @map("firebase_uid")
  email       String   @unique
  username    String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  books          Book[]
  bookReviews    BookReview[]
  bookSaves      BookSave[]
  stories        Story[]
  storyReactions StoryReaction[]
  comments       Comment[]
  followers      Follow[]        @relation("following")
  following      Follow[]        @relation("follower")

  readingLogs     ReadingLog[]
  achievements    UserAchievement[]
  clubMemberships ClubMember[]
  clubDiscussions ClubDiscussion[]
  clubsOwned      Club[]           @relation("club_owner")

  betaReads             BetaReader[]
  newsletterSubscribers NewsletterSubscriber[] @relation("AuthorNewsletters")
  newsletterSubs        NewsletterSubscriber[] @relation("NewsletterSubscriptions")

  tipsSent     Tip[] @relation("TipsSent")
  tipsReceived Tip[] @relation("TipsReceived")

  @@map("users")
}

model Book {
  id            String   @id @default(cuid())
  title         String
  authorName    String   @map("author_name")
  coverUrl      String?  @map("cover_url")
  fileUrl       String   @map("file_url")
  fileType      FileType @map("file_type")
  genre         String
  language      String   @default("English")
  description   String?
  downloadCount Int      @default(0) @map("download_count")
  uploadedById  String   @map("uploaded_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  uploadedBy User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  reviews    BookReview[]
  saves      BookSave[]
  comments   Comment[]

  @@index([genre])
  @@index([uploadedById])
  @@map("books")
}

model BookReview {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@map("book_reviews")
}

model BookSave {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@map("book_saves")
}

model Story {
  id        String   @id @default(cuid())
  title     String
  coverUrl  String?  @map("cover_url")
  summary   String?
  authorId  String   @map("author_id")
  viewCount Int      @default(0) @map("view_count")
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  chapters    StoryChapter[]
  reactions   StoryReaction[]
  comments    Comment[]
  betaReaders BetaReader[]
  tips        Tip[]

  @@index([authorId])
  @@index([published])
  @@map("stories")
}

model StoryChapter {
  id           String        @id @default(cuid())
  storyId      String        @map("story_id")
  title        String
  content      Json?
  chapterOrder Int           @map("chapter_order")
  status       ChapterStatus @default(PUBLISHED)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, chapterOrder])
  @@map("story_chapters")
}

model StoryReaction {
  id           String       @id @default(cuid())
  storyId      String       @map("story_id")
  userId       String       @map("user_id")
  reactionType ReactionType @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_reactions")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String   @map("author_id")
  storyId   String?  @map("story_id")
  bookId    String?  @map("book_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  story   Story?    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  book    Book?     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([storyId])
  @@index([bookId])
  @@index([parentId])
  @@map("comments")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// --- Gamification Models (Batch 2) ---

model ReadingLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  pagesRead Int      @default(0) @map("pages_read")
  minutes   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("reading_logs")
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String?
  points      Int      @default(10)
  createdAt   DateTime @default(now()) @map("created_at")

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// --- Book Clubs & Communities Models (Batch 2) ---

model Club {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  coverUrl    String?  @map("cover_url")
  ownerId     String   @map("owner_id")
  genre       String?
  isPrivate   Boolean  @default(false) @map("is_private")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       User             @relation("club_owner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ClubMember[]
  discussions ClubDiscussion[]

  @@index([ownerId])
  @@map("clubs")
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String   @map("club_id")
  userId   String   @map("user_id")
  role     ClubRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_members")
}

model ClubDiscussion {
  id        String   @id @default(cuid())
  clubId    String   @map("club_id")
  authorId  String   @map("author_id")
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club   Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([authorId])
  @@map("club_discussions")
}

// --- Creator Tools Models (Batch 3) ---

model BetaReader {
  id        String   @id @default(cuid())
  storyId   String   @map("story_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("beta_readers")
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  authorId     String   @map("author_id")
  subscriberId String   @map("subscriber_id")
  createdAt    DateTime @default(now()) @map("created_at")

  author     User @relation("AuthorNewsletters", fields: [authorId], references: [id], onDelete: Cascade)
  subscriber User @relation("NewsletterSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([authorId, subscriberId])
  @@map("newsletter_subscribers")
}

// --- Monetisation Models (Batch 4) ---

model Tip {
  id              String    @id @default(cuid())
  amount          Int       
  currency        String    @default("usd")
  senderId        String?   @map("sender_id") 
  receiverId      String    @map("receiver_id")
  storyId         String?   @map("story_id")
  message         String?
  stripeSessionId String?   @unique @map("stripe_session_id")
  status          TipStatus @default(PENDING)
  createdAt       DateTime  @default(now()) @map("created_at")

  sender   User?  @relation("TipsSent", fields: [senderId], references: [id], onDelete: SetNull)
  receiver User   @relation("TipsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  story    Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([receiverId])
  @@map("tips")
}
