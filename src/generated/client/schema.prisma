generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  VISITOR
  MEMBER
  AUTHOR
  ADMIN
}

enum FileType {
  PDF
  EPUB
}

enum ReactionType {
  LIKE
  LOVE
  FIRE
  CRY
  WOW
}

enum ClubRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ChapterStatus {
  DRAFT
  BETA
  PUBLISHED
}

enum TipStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique @map("firebase_uid")
  email       String   @unique
  username    String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  books          Book[]
  bookReviews    BookReview[]
  bookSaves      BookSave[]
  universes      Universe[]
  stories        Story[]
  storyReactions StoryReaction[]
  comments       Comment[]
  followers      Follow[]        @relation("following")
  following      Follow[]        @relation("follower")

  readingLogs     ReadingLog[]
  achievements    UserAchievement[]
  clubMemberships ClubMember[]
  clubDiscussions ClubDiscussion[]
  clubsOwned      Club[]            @relation("club_owner")
  clubBans        ClubBan[]

  betaReads             BetaReader[]
  newsletterSubscribers NewsletterSubscriber[] @relation("AuthorNewsletters")
  newsletterSubs        NewsletterSubscriber[] @relation("NewsletterSubscriptions")

  tipsSent     Tip[] @relation("TipsSent")
  tipsReceived Tip[] @relation("TipsReceived")

  // New fields for enhanced features
  dateOfBirth      DateTime? @map("date_of_birth")
  membershipTier   String?   @map("membership_tier")
  membershipExpiry DateTime? @map("membership_expiry")
  subGenres        String[]  @default([])
  mood             String?
  contentWarnings  String[]  @default([])
  ageRating        Int?      @default(0)
  tags             String[]  @default([])
  reactionCount    Int       @default(0) @map("reaction_count")
  description      String?

  // Relationships to new models
  annotations       BookAnnotation[]
  scheduledChapters ScheduledChapter[]
  inlineComments    InlineComment[]
  shareActivities   ShareActivity[]

  giftsSent                GiftMembership[]          @relation("sender")
  giftsReceived            GiftMembership[]          @relation("receiver")
  onboardingQuiz           OnboardingQuiz?
  contentReports           ContentReport[]           @relation("reporter")
  dmcaNotices              DMCANotice[]              @relation("dmca_submitter")
  notifications            Notification[]            @relation("user_notifications")
  subscriptionTransactions SubscriptionTransaction[]

  @@map("users")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // e.g., "REACT", "COMMENT", "REPLY", "STORY_POST", "DISCUSSION"
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("user_notifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model Book {
  id            String   @id @default(cuid())
  title         String
  authorName    String   @map("author_name")
  coverUrl      String?  @map("cover_url")
  fileUrl       String   @map("file_url")
  fileType      FileType @map("file_type")
  genre         String
  language      String   @default("English")
  description   String?
  downloadCount Int      @default(0) @map("download_count")
  uploadedById  String   @map("uploaded_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  uploadedBy  User             @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  reviews     BookReview[]
  saves       BookSave[]
  comments    Comment[]
  annotations BookAnnotation[]

  @@index([genre])
  @@index([uploadedById])
  @@map("books")
}

model BookReview {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@map("book_reviews")
}

model BookSave {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bookId, userId])
  @@map("book_saves")
}

model Story {
  id              String   @id @default(cuid())
  title           String
  coverUrl        String?  @map("cover_url")
  summary         String?
  description     String?
  authorId        String   @map("author_id")
  viewCount       Int      @default(0) @map("view_count")
  reactionCount   Int      @default(0) @map("reaction_count")
  published       Boolean  @default(false)
  genre           String?
  universeId      String?  @map("universe_id")
  sequenceNumber  Int?     @map("sequence_number")
  subGenres       String[] @default([])
  mood            String?
  contentWarnings String[] @default([])
  ageRating       Int?     @default(0)
  tags            String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  universe    Universe?       @relation("story_universe", fields: [universeId], references: [id], onDelete: SetNull)
  chapters    StoryChapter[]
  reactions   StoryReaction[]
  comments    Comment[]
  betaReaders BetaReader[]
  tips        Tip[]

  // New relationships
  inlineComments  InlineComment[]
  shareActivities ShareActivity[]
  promotions      StoryPromotion[]

  @@index([authorId])
  @@index([published])
  @@index([universeId])
  @@map("stories")
}

model StoryChapter {
  id            String        @id @default(cuid())
  storyId       String        @map("story_id")
  title         String
  content       Json?
  chapterNumber Int           @map("chapter_number")
  chapterOrder  Int           @map("chapter_order")
  status        ChapterStatus @default(PUBLISHED)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, chapterOrder])
  @@map("story_chapters")
}

model StoryReaction {
  id           String       @id @default(cuid())
  storyId      String       @map("story_id")
  userId       String       @map("user_id")
  reactionType ReactionType @map("reaction_type")
  createdAt    DateTime     @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_reactions")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String   @map("author_id")
  storyId   String?  @map("story_id")
  bookId    String?  @map("book_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  story   Story?    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  book    Book?     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([storyId])
  @@index([bookId])
  @@index([parentId])
  @@map("comments")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// --- Gamification Models (Batch 2) ---

model ReadingLog {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  storyId              String?  @map("story_id")
  date                 DateTime @db.Date
  pagesRead            Int      @default(0) @map("pages_read")
  minutes              Int      @default(0)
  readTime             Int?     @map("read_time")
  sessionsToCompletion Boolean? @map("sessions_to_completion")
  createdAt            DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("reading_logs")
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String?
  points      Int      @default(10)
  createdAt   DateTime @default(now()) @map("created_at")

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// --- Book Clubs & Communities Models (Batch 2) ---

model Club {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  coverUrl    String?  @map("cover_url")
  ownerId     String   @map("owner_id")
  genre       String?
  isPrivate   Boolean  @default(false) @map("is_private")
  maxMembers  Int?     @map("max_members")
  joinCode    String?  @unique @map("join_code")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner       User             @relation("club_owner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ClubMember[]
  discussions ClubDiscussion[]
  bannedUsers ClubBan[]

  @@index([ownerId])
  @@index([joinCode])
  @@map("clubs")
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String   @map("club_id")
  userId   String   @map("user_id")
  role     ClubRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_members")
}

model ClubBan {
  id       String   @id @default(cuid())
  clubId   String   @map("club_id")
  userId   String   @map("user_id")
  reason   String?
  bannedAt DateTime @default(now()) @map("banned_at")
  bannedBy String   @map("banned_by")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@map("club_bans")
}

model ClubDiscussion {
  id        String   @id @default(cuid())
  clubId    String   @map("club_id")
  authorId  String   @map("author_id")
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([authorId])
  @@map("club_discussions")
}

// --- Creator Tools Models (Batch 3) ---

model BetaReader {
  id        String   @id @default(cuid())
  storyId   String   @map("story_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("beta_readers")
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  authorId     String   @map("author_id")
  subscriberId String   @map("subscriber_id")
  createdAt    DateTime @default(now()) @map("created_at")

  author     User @relation("AuthorNewsletters", fields: [authorId], references: [id], onDelete: Cascade)
  subscriber User @relation("NewsletterSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([authorId, subscriberId])
  @@map("newsletter_subscribers")
}

// --- Monetisation Models (Batch 4) ---

model Tip {
  id              String    @id @default(cuid())
  amount          Int
  currency        String    @default("usd")
  senderId        String?   @map("sender_id")
  receiverId      String    @map("receiver_id")
  storyId         String?   @map("story_id")
  message         String?
  stripeSessionId String?   @unique @map("stripe_session_id")
  status          TipStatus @default(PENDING)
  createdAt       DateTime  @default(now()) @map("created_at")

  sender   User?  @relation("TipsSent", fields: [senderId], references: [id], onDelete: SetNull)
  receiver User   @relation("TipsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  story    Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([receiverId])
  @@map("tips")
}

// --- Deep Gap Analysis Features (Wave 5) ---

enum AnnotationType {
  BOOKMARK
  HIGHLIGHT
  NOTE
}

model BookAnnotation {
  id              String         @id @default(cuid())
  bookId          String         @map("book_id")
  userId          String         @map("user_id")
  type            AnnotationType
  pageNumber      Int            @map("page_number")
  content         String?
  highlightColor  String?        @map("highlight_color")
  highlightedText String?        @map("highlighted_text")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookId, userId])
  @@map("book_annotations")
}

model ScheduledChapter {
  id              String   @id @default(cuid())
  storyId         String   @map("story_id")
  chapterNumber   Int      @map("chapter_number")
  releaseDateTime DateTime @map("release_date_time")
  notifyFollowers Boolean  @default(true) @map("notify_followers")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("scheduled_chapters")
}

model InlineComment {
  id           String   @id @default(cuid())
  storyId      String   @map("story_id")
  paragraphId  String   @map("paragraph_id")
  content      String
  authorId     String   @map("author_id")
  spoilerAlert Boolean  @default(false) @map("spoiler_alert")
  parentId     String?  @map("parent_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  story   Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  author  User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  InlineComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies InlineComment[] @relation("CommentThread")

  @@index([storyId])
  @@index([authorId])
  @@map("inline_comments")
}

model ShareActivity {
  id        String   @id @default(cuid())
  storyId   String   @map("story_id")
  platform  String // Twitter, Instagram, Facebook, TikTok
  sharedBy  String?  @map("shared_by")
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [sharedBy], references: [id], onDelete: SetNull)

  @@index([storyId])
  @@map("share_activities")
}

model OnboardingQuiz {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  genrePreferences String[]
  readingLevel     String?  @default("INTERMEDIATE")
  favoriteAuthors  String[]
  completed        Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_quizzes")
}

model ContentReport {
  id         String   @id @default(cuid())
  reportedBy String   @map("reported_by")
  storyId    String   @map("story_id")
  reason     String // COPYRIGHTED, EXPLICIT, HATE_SPEECH, HARASSMENT, OTHER
  status     String   @default("PENDING") // PENDING, REVIEWED, RESOLVED, DISMISSED
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  reporter User @relation("reporter", fields: [reportedBy], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("content_reports")
}

model DMCANotice {
  id                 String   @id @default(cuid())
  storyId            String   @map("story_id")
  originalWorkTitle  String   @map("original_work_title")
  originalWorkAuthor String?  @map("original_work_author")
  copyrightHolder    String   @map("copyright_holder")
  description        String?
  submittedBy        String   @map("submitted_by")
  status             String   @default("SUBMITTED") // SUBMITTED, ACKNOWLEDGED, RESOLVED, DISMISSED
  createdAt          DateTime @default(now()) @map("created_at")

  submittedByUser User @relation("dmca_submitter", fields: [submittedBy], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("dmca_notices")
}

model StoryPromotion {
  id        String   @id @default(cuid())
  storyId   String   @map("story_id")
  tier      String // FEATURED, PROMOTED, TRENDING
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  cost      Float
  status    String   @default("ACTIVE") // ACTIVE, ENDED, PAUSED
  createdAt DateTime @default(now()) @map("created_at")

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("story_promotions")
}

model GiftMembership {
  id             String    @id @default(cuid())
  code           String    @unique
  tier           String // PRO, CREATOR
  duration       Int // in months
  sentBy         String    @map("sent_by")
  recipientEmail String    @map("recipient_email")
  redeemById     String?   @map("redeemed_by")
  value          Float
  expiresAt      DateTime  @map("expires_at")
  redeemedAt     DateTime? @map("redeemed_at")
  status         String    @default("PENDING") // PENDING, REDEEMED, EXPIRED
  createdAt      DateTime  @default(now()) @map("created_at")

  sentByUser     User  @relation("sender", fields: [sentBy], references: [id], onDelete: Cascade)
  redeemedByUser User? @relation("receiver", fields: [redeemById], references: [id], onDelete: SetNull)

  @@index([sentBy])
  @@map("gift_memberships")
}

model Universe {
  id          String   @id @default(cuid())
  name        String
  description String?
  genre       String   @default("Fiction")
  coverUrl    String?  @map("cover_url")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories Story[] @relation("story_universe")

  @@index([userId])
  @@map("universes")
}

model SubscriptionTransaction {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  plan          String // PRO or CREATOR
  duration      Int // in months
  amount        Float
  senderNumber  String   @map("sender_number")
  transactionId String   @unique @map("transaction_id")
  status        String   @default("PENDING") // PENDING, APPROVED, DECLINED
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription_transactions")
}
